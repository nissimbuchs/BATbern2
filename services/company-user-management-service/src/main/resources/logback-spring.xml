<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        Structured JSON logging configuration for CloudWatch Logs integration.

        Logs are formatted as JSON with:
        - Correlation ID from MDC for distributed tracing
        - Application and environment metadata
        - Standard fields: timestamp, level, logger, message, exception
    -->

    <!-- Get Spring profile for environment tagging -->
    <springProperty scope="context" name="springAppName" source="spring.application.name" defaultValue="company-user-management-service"/>
    <springProperty scope="context" name="springProfile" source="spring.profiles.active" defaultValue="development"/>

    <!-- Console appender with JSON encoding for CloudWatch Logs -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Include correlation ID from MDC -->
            <includeMdcKeyName>correlationId</includeMdcKeyName>

            <!-- Add custom fields for application and environment -->
            <customFields>{"application":"${springAppName}","environment":"${springProfile}"}</customFields>

            <!-- Include stack traces for exceptions -->
            <includeContext>true</includeContext>
            <includeCallerData>false</includeCallerData>

            <!-- Timestamp format -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSX</timestampPattern>
        </encoder>
    </appender>

    <!-- Root logger configuration -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Service-specific logging -->
    <logger name="ch.batbern.companyuser" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Spring framework logging -->
    <logger name="org.springframework" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Hibernate SQL logging (for debugging) -->
    <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- AWS SDK logging -->
    <logger name="software.amazon.awssdk" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- Micrometer metrics logging -->
    <logger name="io.micrometer" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

    <!-- X-Ray tracing logging -->
    <logger name="com.amazonaws.xray" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>
</configuration>
