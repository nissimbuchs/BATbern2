# Development Dockerfile with hot reload support for speaker-coordination-service
FROM gradle:8.5-jdk21

WORKDIR /workspace

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create non-root user (gradle image already has gradle user)
# Ensure gradle user owns the workspace and cache
RUN mkdir -p /gradle-cache && \
    chown -R gradle:gradle /workspace /gradle-cache

# Copy Gradle wrapper and settings
COPY --chown=gradle:gradle settings.gradle ./
COPY --chown=gradle:gradle gradle ./gradle
COPY --chown=gradle:gradle gradlew ./

# Copy shared-kernel dependency
COPY --chown=gradle:gradle shared-kernel/build.gradle ./shared-kernel/
COPY --chown=gradle:gradle shared-kernel/src ./shared-kernel/src

# Copy service build file
COPY --chown=gradle:gradle services/speaker-coordination-service/build.gradle ./services/speaker-coordination-service/

# Download dependencies (cached layer)
RUN gradle :services:speaker-coordination-service:dependencies --no-daemon || true

# Copy source code
COPY --chown=gradle:gradle services/speaker-coordination-service/src ./services/speaker-coordination-service/src

WORKDIR /workspace/services/speaker-coordination-service

# Set unique Gradle user home to avoid cache conflicts
ENV GRADLE_USER_HOME=/gradle-cache

# Switch to non-root user
USER gradle

# Expose application port and debug port
EXPOSE 8080
EXPOSE 5005

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/actuator/health || exit 1

# Run with Gradle bootRun for hot reload
# Use project-specific task to avoid multi-project conflicts
ENTRYPOINT ["gradle", ":services:speaker-coordination-service:bootRun", "--no-daemon", "--project-cache-dir=/gradle-cache/project-cache"]
