FROM flyway/flyway:10-alpine

# Create non-root user
RUN addgroup -g 1001 -S flyway && \
    adduser -S flyway -u 1001

# Copy migration files
COPY --chown=flyway:flyway shared-kernel/src/main/resources/db/migration /flyway/sql

# Add PostgreSQL driver (already included in flyway image)
# Set working directory
WORKDIR /flyway

# Switch to non-root user
USER flyway

# Entrypoint will be flyway command
ENTRYPOINT ["flyway"]
CMD ["migrate"]
