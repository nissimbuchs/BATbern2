# Multi-Role E2E Test User Credentials
# ======================================
# Copy this file to .env.test.local and fill in real credentials.
# .env.test.local is gitignored — NEVER commit real credentials.
#
# Usage:
#   make setup-test-users                    # authenticate all roles (staging)
#   make setup-test-users ENV=development    # authenticate for development
#
# Only ORGANIZER credentials are required. SPEAKER and PARTNER are optional —
# tests for those roles are skipped when credentials are not configured.

# ORGANIZER: Full admin access, manages events, partners, meetings, speakers
ORGANIZER_EMAIL=organizer@batbern.ch
ORGANIZER_PASSWORD=

# SPEAKER: Speaker self-service portal access
# Must be a Cognito user with custom:role = SPEAKER
SPEAKER_EMAIL=speaker@batbern.ch
SPEAKER_PASSWORD=

# PARTNER: Partner portal access (Epic 8)
# Must be a Cognito user with custom:role = PARTNER
PARTNER_EMAIL=partner@batbern.ch
PARTNER_PASSWORD=
