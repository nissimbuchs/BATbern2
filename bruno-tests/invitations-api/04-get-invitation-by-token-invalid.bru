meta {
  name: Get Invitation by Invalid Token
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/invitations/respond/invalid-token-that-does-not-exist-12345
  body: none
  auth: none
}

docs {
  # Public Endpoint - No Authentication Required

  Tests the GET /invitations/respond/{token} endpoint with an invalid token.

  Note: Response tokens are sent via email only (security requirement).
  Successful token flow is validated in integration tests where we have
  database access to retrieve the token.

  This test validates:
  - Endpoint is accessible without authentication
  - Invalid tokens return 404 Not Found
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 for invalid token - Story 6.1 AC2", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should be accessible without authentication (public endpoint) - Story 6.1 AC2", function() {
    // If we got here without auth and received 404 (not 401/403),
    // the endpoint is correctly public
    expect(res.getStatus()).to.not.equal(401);
    expect(res.getStatus()).to.not.equal(403);
  });

  test("should return error response with message", function() {
    const body = res.getBody();
    // Endpoint returns error structure
    expect(body.error || body.message || body.status).to.exist;
  });
}
