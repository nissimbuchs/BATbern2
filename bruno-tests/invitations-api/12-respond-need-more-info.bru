meta {
  name: Respond Need More Info (Structure Test)
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/invitations/respond/test-tentative-response-invalid-token-xyz
  body: json
  auth: none
}

docs {
  # Public Endpoint - No Authentication Required

  Story 6.2: Speaker Self-Service Response Portal

  Tests the POST /invitations/respond/{token} endpoint with TENTATIVE response
  (displayed as "Need More Info" in the UI).

  Note: This test validates request body structure. Actual successful flow
  is validated in integration tests where we have database access.

  Validates:
  - Public endpoint accessibility (no auth required)
  - Request body structure for tentative/need-more-info response
  - Invalid tokens return 404 (not auth errors)
}

body:json {
  {
    "responseType": "TENTATIVE",
    "notes": "I'm interested but have some questions: What is the expected audience size? Will there be other speakers covering similar topics? What is the presentation duration?"
  }
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 for invalid token - Story 6.2 AC4", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should be accessible without authentication (public endpoint) - Story 6.2 AC1", function() {
    // If we got here without auth and received 404 (not 401/403),
    // the endpoint is correctly public
    expect(res.getStatus()).to.not.equal(401);
    expect(res.getStatus()).to.not.equal(403);
  });

  test("should accept TENTATIVE as valid response type - Story 6.2 AC4", function() {
    // Validated by reaching this point without parse errors
    // TENTATIVE is the backend enum value for "Need More Info" UI label
    const body = res.getBody();
    expect(body.error || body.message || body.status).to.exist;
  });
}
