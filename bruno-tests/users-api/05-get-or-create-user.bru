meta {
  name: Get or Create User
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/users/get-or-create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{serviceAuthToken}}
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "email": "bruno-test-{{$timestamp}}@example.com",
    "firstName": "Bruno",
    "lastName": "Test",
    "role": "ATTENDEE"
  }
}

assert {
  res.status: eq 200
  res.body.user: isDefined
}

script:post-response {
  // Store created user for cleanup
  if (res.getStatus() === 200) {
    const response = res.getBody();
    bru.setEnvVar("testUsername", response.user.id);
    console.log("Created/retrieved user:", response.user.id);
  }
}

tests {
  test("should get-or-create user successfully (AC12)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return user with created flag", function() {
    const body = res.getBody();
    expect(body.user).to.exist;
    expect(body.created).to.be.a('boolean');
  });

  test("should be idempotent (second call returns same user)", function() {
    // This would need to be tested with a second request
    expect(res.getStatus()).to.equal(200);
  });

  test("should require service-to-service auth", function() {
    // Verified by 401 if regular user token used
    expect(res.getStatus()).to.equal(200);
  });
}
