meta {
  name: List Users - Filter Active Users (true)
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/users?filter="active":true&page=1&limit=20
  body: none
  auth: bearer
}

params:query {
  filter: "active":true
  page: 1
  limit: 20
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: in [200, 403, 429]
}

tests {
  test("should filter active users successfully", function() {
    const status = res.getStatus();
    expect([200, 403, 429]).to.include(status);
    if (status === 403) {
      console.log("Non-admin/organizer - access denied (expected)");
    }
  });
  
  test("should return only active users", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.data).to.be.an('array');
  
      // Verify all returned users are active
      body.data.forEach(user => {
        expect(user.active).to.equal(true);
      });
  
      console.log(`Found ${body.data.length} active users`);
    }
  });
  
  test("should return pagination metadata", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.pagination).to.exist;
    }
  });
}
