meta {
  name: List Users - Combined Filters (role + active + search)
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
}

params:query {
  role: ATTENDEE
  filter: {"active":true}
  search: bruno
  page: 1
  limit: 20
}

assert {
  res.status: in [200, 403, 429]
}

tests {
  test("should apply all filters successfully", function() {
    const status = res.getStatus();
    expect([200, 403, 429]).to.include(status);
    if (status === 403) {
      console.log("Non-admin/organizer - access denied (expected)");
    }
  });

  test("should return users matching all filter criteria", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.data).to.be.an('array');

      // Verify all filters are applied correctly
      body.data.forEach(user => {
        // Must have ATTENDEE role
        expect(user.roles).to.be.an('array');
        expect(user.roles).to.include('ATTENDEE');

        // Must be active
        expect(user.active).to.equal(true);

        // Must match search term
        const searchTerm = 'bruno';
        const matchesFirstName = user.firstName && user.firstName.toLowerCase().includes(searchTerm);
        const matchesLastName = user.lastName && user.lastName.toLowerCase().includes(searchTerm);
        const matchesEmail = user.email && user.email.toLowerCase().includes(searchTerm);
        const matchesUsername = user.id && user.id.toLowerCase().includes(searchTerm);

        const matches = matchesFirstName || matchesLastName || matchesEmail || matchesUsername;
        expect(matches).to.be.true;
      });

      if (body.data.length > 0) {
        console.log(`Found ${body.data.length} users matching all criteria (ATTENDEE + active + 'bruno')`);
      } else {
        console.log('No users match all filter criteria (this may be expected)');
      }
    }
  });

  test("should return pagination metadata", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.pagination).to.exist;
      expect(body.pagination.page).to.equal(1);
      expect(body.pagination.limit).to.equal(20);
    }
  });
}
