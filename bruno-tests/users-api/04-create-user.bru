meta {
  name: Create User (Admin/Organizer)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "email": "bruno-test-{{$timestamp}}@example.com",
    "firstName": "Bruno",
    "lastName": "TestUser",
    "initialRoles": ["ATTENDEE"],
    "bio": "Test user created via Bruno API tests"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.email: isDefined
}

script:post-response {
  // Store created user for subsequent tests
  if (res.getStatus() === 201) {
    const user = res.getBody();
    bru.setEnvVar("testUsername", user.id);
    bru.setEnvVar("testUserEmail", user.email);
    console.log("Created test user:", user.id);
    console.log("Test user email:", user.email);
  }
}

tests {
  test("should create user successfully (AC4)", function() {
    const status = res.getStatus();
    // Should be 201 for admin/organizer, 403 for others
    expect([201, 403]).to.include(status);
  });

  test("should return created user with username as id", function() {
    if (res.getStatus() === 201) {
      const body = res.getBody();
      expect(body.id).to.exist;
      expect(body.id).to.be.a('string');
      expect(body.id).to.match(/^[a-z]+\.[a-z]+(\.[0-9]+)?$/); // username format: bruno.testuser or bruno.testuser.1
    }
  });

  test("should return user with all required fields", function() {
    if (res.getStatus() === 201) {
      const body = res.getBody();
      expect(body.email).to.exist;
      expect(body.firstName).to.equal("Bruno");
      expect(body.lastName).to.equal("TestUser");
      expect(body.roles).to.be.an('array');
      expect(body.roles).to.include('ATTENDEE');
    }
  });

  test("should require admin/organizer role", function() {
    const status = res.getStatus();
    if (status === 403) {
      console.log("Correctly denied access for non-admin/organizer");
    }
  });

  test("should complete within performance target (<150ms P95)", function() {
    if (res.getStatus() === 201) {
      const responseTime = res.getResponseTime();
      expect(responseTime).to.be.lessThan(200); // Allow some margin
    }
  });
}
