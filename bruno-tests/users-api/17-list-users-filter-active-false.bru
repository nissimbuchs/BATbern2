meta {
  name: List Users - Filter Inactive Users (false)
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
}

params:query {
  filter: {"active":false}
  page: 1
  limit: 20
}

assert {
  res.status: in [200, 403, 429]
}

tests {
  test("should filter inactive users successfully", function() {
    const status = res.getStatus();
    expect([200, 403, 429]).to.include(status);
    if (status === 403) {
      console.log("Non-admin/organizer - access denied (expected)");
    }
  });

  test("should return only inactive users", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.data).to.be.an('array');

      // Verify all returned users are inactive (if any are returned)
      if (body.data.length > 0) {
        body.data.forEach(user => {
          expect(user.active).to.equal(false);
        });
      }

      console.log(`Found ${body.data.length} inactive users`);
    }
  });

  test("should return pagination metadata", function() {
    if (res.getStatus() === 200) {
      const body = res.getBody();
      expect(body.pagination).to.exist;
    }
  });
}
