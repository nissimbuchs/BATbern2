meta {
  name: Setup Test Event for Speaker Portal
  type: http
  seq: 0
}

post {
  url: {{baseUrl}}/events
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "title": "Speaker Portal Test Event",
    "eventNumber": 999,
    "description": "Test event for speaker portal E2E tests",
    "date": "2026-06-15T18:00:00Z",
    "registrationDeadline": "2026-06-10T23:59:59Z",
    "venueName": "Test Venue",
    "venueAddress": "Test Address 1, 3000 Bern",
    "venueCapacity": 100,
    "eventType": "EVENING",
    "organizerUsername": "{{organizerUsername}}"
  }
}

assert {
  res.status: in [201, 422]
}

tests {
  test("should create test event or find existing one for speaker portal tests", function() {
    const status = res.getStatus();
    if (status === 201) {
      const event = res.getBody();
      expect(event.eventCode).to.be.a('string');
      bru.setVar("speakerPortalTestEventCode", event.eventCode);
    } else {
      // 422 means eventNumber 999 already exists - use BATbern999
      bru.setVar("speakerPortalTestEventCode", "BATbern999");
    }
    const eventCode = bru.getVar("speakerPortalTestEventCode");
    expect(eventCode).to.be.a('string');
    console.log("Test event code: " + eventCode);
  });
}
