meta {
  name: Send Invitation Email (Story 6.1b)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/events/{{speakerPortalTestEventCode}}/speakers/{{invitedSpeakerUsername}}/send-invitation
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "responseDeadline": "2026-07-01"
  }
}

assert {
  res.status: eq 200
  res.body.status: isDefined
}

tests {
  test("should send invitation email - Story 6.1b AC4", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should transition workflow state to INVITED - Story 6.1b AC5", function() {
    const body = res.getBody();
    expect(body.status).to.equal('INVITED');
  });

  test("should set invitedAt timestamp - Story 6.1b AC6", function() {
    const body = res.getBody();
    expect(body.invitedAt).to.be.a('string');
  });
}
