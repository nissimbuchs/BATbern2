meta {
  name: Get E2E Test Token for Decline Speaker
  type: http
  seq: 9.5
}

post {
  url: {{baseUrl}}/e2e-test/tokens/generate-for-speaker?eventCode={{speakerPortalTestEventCode}}&username={{declineSpeakerUsername}}
  body: none
  auth: none
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.tokens: isDefined
}

tests {
  test("should generate test tokens for decline speaker - E2E helper", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.tokens).to.exist;
    bru.setVar("declineSpeakerToken", body.tokens.RESPOND);
    console.log("Set declineSpeakerToken for decline test");
  });
}
