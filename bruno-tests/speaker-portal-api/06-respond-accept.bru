meta {
  name: Accept Invitation (Story 6.2a)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/speaker-portal/respond
  body: json
  auth: none
}

body:json {
  {
    "token": "{{speakerMagicToken}}",
    "response": "ACCEPT",
    "preferences": {
      "timeSlot": "morning",
      "travelRequirements": "local",
      "initialTitle": "Building Scalable Microservices",
      "comments": "Looking forward to the event!"
    }
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("should accept invitation successfully - Story 6.2a AC3", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.success).to.be.true;
  });

  test("should return next steps - Story 6.2a AC3", function() {
    const body = res.getBody();
    expect(body.nextSteps).to.be.an('array');
    expect(body.nextSteps.length).to.be.greaterThan(0);
  });

  test("should return profileUrl with VIEW token - Story 6.2a AC3", function() {
    const body = res.getBody();
    if (body.profileUrl) {
      // Extract VIEW token from profileUrl using string parsing (URL API not available in Bruno VM)
      const profileUrl = body.profileUrl;
      const tokenIndex = profileUrl.indexOf('token=');
      if (tokenIndex !== -1) {
        const tokenStart = tokenIndex + 6;
        const ampIndex = profileUrl.indexOf('&', tokenStart);
        const viewToken = ampIndex !== -1
          ? profileUrl.substring(tokenStart, ampIndex)
          : profileUrl.substring(tokenStart);
        if (viewToken) {
          bru.setVar("speakerViewToken", viewToken);
          console.log("Extracted VIEW token from profileUrl for content submission tests");
        }
      }
    }
  });
}
