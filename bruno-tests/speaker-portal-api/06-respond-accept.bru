meta {
  name: Accept Invitation (Story 6.2a)
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/speaker-portal/respond
  body: json
  auth: none
}

body:json {
  {
    "token": "{{speakerMagicToken}}",
    "response": "ACCEPT",
    "preferences": {
      "timeSlotPreference": "Morning sessions preferred",
      "travelRequirements": "None",
      "technicalNeeds": "HDMI adapter for Mac",
      "initialTitle": "Building Scalable Microservices",
      "comments": "Looking forward to the event!"
    }
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.newWorkflowState: eq ACCEPTED
}

tests {
  test("should accept invitation successfully - Story 6.2a AC3", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.success).to.be.true;
  });

  test("should transition to ACCEPTED state - Story 6.2a AC3", function() {
    const body = res.getBody();
    expect(body.newWorkflowState).to.equal('ACCEPTED');
  });

  test("should return next steps - Story 6.2a AC3", function() {
    const body = res.getBody();
    expect(body.nextSteps).to.be.an('array');
    expect(body.nextSteps.length).to.be.greaterThan(0);
  });

  test("should consume token (single-use) - Story 6.2a AC3", function() {
    const body = res.getBody();
    expect(body.tokenConsumed).to.be.true;
  });

  test("should return profileUrl with VIEW token - Story 6.2a AC3", function() {
    const body = res.getBody();
    if (body.profileUrl) {
      // Extract VIEW token from profileUrl for use in content submission tests
      const url = new URL(body.profileUrl);
      const viewToken = url.searchParams.get('token');
      if (viewToken) {
        bru.setVar("speakerViewToken", viewToken);
        console.log("Extracted VIEW token for content submission tests");
      }
    }
  });
}
