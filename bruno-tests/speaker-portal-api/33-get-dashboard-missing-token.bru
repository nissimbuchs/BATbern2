meta {
  name: Get Dashboard Missing Token (Story 6.4)
  type: http
  seq: 33
}

get {
  url: {{baseUrl}}/speaker-portal/dashboard
  body: none
  auth: none
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 when no token provided - Story 6.4 AC1", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should include validation error message - Story 6.4 AC1", function() {
    const body = res.getBody();
    expect(body.message || body.error).to.be.a('string');
  });
}
