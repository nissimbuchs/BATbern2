meta {
  name: Validate Invalid Token (Story 6.1a)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/speaker-portal/validate-token
  body: json
  auth: none
}

body:json {
  {
    "token": "invalid-token-that-does-not-exist"
  }
}

assert {
  res.status: eq 401
  res.body.error: isDefined
}

tests {
  test("should return 401 for invalid token - Story 6.1a AC5", function() {
    expect(res.getStatus()).to.equal(401);
  });

  test("should return appropriate error code - Story 6.1a AC6", function() {
    const body = res.getBody();
    expect(['NOT_FOUND', 'EXPIRED', 'ALREADY_USED']).to.include(body.error);
  });
}
