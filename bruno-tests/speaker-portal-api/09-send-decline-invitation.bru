meta {
  name: Send Invitation for Decline Test
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/events/{{speakerPortalTestEventCode}}/speakers/{{declineSpeakerUsername}}/send-invitation
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "responseDeadline": "2026-07-01"
  }
}

tests {
  test("should send invitation for decline test", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.status).to.equal('INVITED');
  });
}
