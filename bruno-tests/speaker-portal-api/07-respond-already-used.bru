meta {
  name: Respond with Already Used Token (Story 6.2a)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/speaker-portal/respond
  body: json
  auth: none
}

body:json {
  {
    "token": "{{speakerMagicToken}}",
    "response": "ACCEPT"
  }
}

assert {
  res.status: eq 401
  res.body.details.errorCode: isDefined
}

tests {
  test("should reject already used token - Story 6.2a AC7", function() {
    expect(res.getStatus()).to.equal(401);
  });

  test("should return ALREADY_USED error code - Story 6.2a AC7", function() {
    const body = res.getBody();
    expect(body.details.errorCode).to.equal('ALREADY_USED');
  });
}
