meta {
  name: Respond with Already Used Token (Story 6.2a)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/speaker-portal/respond
  body: json
  auth: none
}

body:json {
  {
    "token": "{{speakerMagicToken}}",
    "response": "ACCEPT"
  }
}

assert {
  res.status: eq 401
  res.body.errorCode: eq TOKEN_ALREADY_USED
}

tests {
  test("should reject already used token - Story 6.2a AC7", function() {
    expect(res.getStatus()).to.equal(401);
  });

  test("should return TOKEN_ALREADY_USED error - Story 6.2a AC7", function() {
    const body = res.getBody();
    expect(body.errorCode).to.equal('TOKEN_ALREADY_USED');
  });

  test("should include previous response info - Story 6.2a AC7", function() {
    const body = res.getBody();
    expect(body.previousResponse).to.equal('ACCEPTED');
    expect(body.respondedAt).to.be.a('string');
  });
}
