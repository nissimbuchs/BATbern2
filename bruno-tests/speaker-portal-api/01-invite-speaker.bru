meta {
  name: Invite Speaker (Story 6.1b)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/events/{{speakerPortalTestEventCode}}/speakers/invite
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "email": "speaker-test-{{$guid}}@example.com",
    "firstName": "Test",
    "lastName": "Speaker",
    "company": "Test Company AG",
    "notes": "Software Architecture, Cloud Computing"
  }
}

assert {
  res.status: in [200, 201]
  res.body.username: isDefined
  res.body.speakerPoolId: isDefined
}

tests {
  test("should invite speaker successfully - Story 6.1b AC1", function() {
    const status = res.getStatus();
    expect(status === 200 || status === 201).to.be.true;
  });

  test("should return speaker details with username - Story 6.1b AC2", function() {
    const body = res.getBody();
    expect(body.username).to.be.a('string');
    expect(body.speakerPoolId).to.be.a('string');
    bru.setVar("invitedSpeakerUsername", body.username);
    bru.setVar("invitedSpeakerPoolId", body.speakerPoolId);
  });

  test("should set workflow state to IDENTIFIED or INVITED - Story 6.1b AC3", function() {
    const body = res.getBody();
    expect(['IDENTIFIED', 'INVITED']).to.include(body.status);
  });
}
