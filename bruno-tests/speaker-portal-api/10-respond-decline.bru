meta {
  name: Decline Invitation (Story 6.2a)
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/speaker-portal/respond
  body: json
  auth: none
}

body:json {
  {
    "token": "{{declineSpeakerToken}}",
    "response": "DECLINE",
    "reason": "Schedule conflict with another commitment",
    "alternativeSuggestion": "You might consider reaching out to Dr. Example"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.newWorkflowState: eq DECLINED
}

tests {
  test("should decline invitation successfully - Story 6.2a AC4", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.success).to.be.true;
  });

  test("should transition to DECLINED state (terminal) - Story 6.2a AC4", function() {
    const body = res.getBody();
    expect(body.newWorkflowState).to.equal('DECLINED');
  });

  test("should consume token - Story 6.2a AC4", function() {
    const body = res.getBody();
    expect(body.tokenConsumed).to.be.true;
  });
}
