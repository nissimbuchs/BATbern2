meta {
  name: Get Speaker Profile (Story 6.2b)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/speaker-portal/profile?token={{speakerMagicToken}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.username: isDefined
  res.body.email: isDefined
}

tests {
  test("should return profile successfully - Story 6.2b AC1", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should include user fields from Company Service - Story 6.2b AC2", function() {
    const body = res.getBody();
    expect(body.username).to.be.a('string');
    expect(body.email).to.be.a('string');
  });

  test("should include speaker-specific fields - Story 6.2b AC3", function() {
    const body = res.getBody();
    // These may be null for new speakers not yet accepted
    expect(body).to.have.property('expertiseAreas');
    expect(body).to.have.property('speakingTopics');
    expect(body).to.have.property('languages');
  });

  test("should include profile completeness indicator - Story 6.2b AC4", function() {
    const body = res.getBody();
    expect(body.profileCompleteness).to.be.a('number');
    expect(body.profileCompleteness).to.be.at.least(0);
    expect(body.profileCompleteness).to.be.at.most(100);
  });
}
