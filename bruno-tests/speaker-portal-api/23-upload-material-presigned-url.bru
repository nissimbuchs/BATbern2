meta {
  name: Get Presigned URL for Material (Story 6.3)
  type: http
  seq: 23
}

post {
  url: {{baseUrl}}/speaker-portal/materials/presigned-url
  body: json
  auth: none
}

body:json {
  {
    "token": "{{speakerViewToken}}",
    "fileName": "cloud-architecture-presentation.pdf",
    "mimeType": "application/pdf",
    "fileSize": 1048576
  }
}

assert {
  res.status: eq 200
  res.body.uploadUrl: isDefined
  res.body.uploadId: isDefined
}

tests {
  test("should return presigned URL - Story 6.3 AC7", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.uploadUrl).to.be.a('string');
    expect(body.uploadUrl).to.include('s3');
    bru.setVar("materialUploadId", body.uploadId);
    bru.setVar("materialUploadUrl", body.uploadUrl);
  });

  test("should return upload ID - Story 6.3 AC7", function() {
    const body = res.getBody();
    expect(body.uploadId).to.be.a('string');
  });

  test("should return expiry time - Story 6.3 AC7", function() {
    const body = res.getBody();
    expect(body.expiresInMinutes).to.be.a('number');
    expect(body.expiresInMinutes).to.be.greaterThan(0);
  });
}
