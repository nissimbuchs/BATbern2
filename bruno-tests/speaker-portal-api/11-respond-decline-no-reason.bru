meta {
  name: Decline Without Reason (Validation Error)
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/events/{{speakerPortalTestEventCode}}/speakers/invite
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "email": "decline-noreason-{{$guid}}@example.com",
    "firstName": "Nodecline",
    "lastName": "Speaker",
    "company": "Test AG"
  }
}

script:post-response {
  // First create and invite the speaker, then we'll test decline without reason
  if (res.getStatus() === 200 || res.getStatus() === 201) {
    bru.setVar("noReasonTestUsername", res.getBody().username);
  }
}

tests {
  test("should setup speaker for no-reason decline test", function() {
    const status = res.getStatus();
    expect(status === 200 || status === 201).to.be.true;
  });
}
