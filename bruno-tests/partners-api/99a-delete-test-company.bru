meta {
  name: Delete Test Company
  type: http
  seq: 99.5
}

docs {
  Cleanup step 2: Deletes the test company created for partner tests.
}

delete {
  url: {{baseUrl}}/companies/{{testPartnerCompanyName}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept: application/json
}

assert {
  res.status: eq 204
}

script:post-response {
  if (res.getStatus() === 204) {
    console.log("Successfully deleted test company:", bru.getEnvVar("testPartnerCompanyName"));
  }
}

tests {
  test("should delete company successfully", function() {
    expect(res.getStatus()).to.equal(204);
  });

  test("should have CORS headers", function() {
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}
