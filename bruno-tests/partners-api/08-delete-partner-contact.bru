meta {
  name: Delete Partner Contact
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/partners/{{testPartnerCompanyName}}/contacts/{{testContactUsername}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Origin: https://staging.batbern.ch
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
}

assert {
  res.status: eq 204
}

tests {
  test("should return 204 status when contact deleted", function() {
    expect(res.getStatus()).to.equal(204);
  });

  test("should not return body on successful deletion", function() {
    expect(res.getBody()).to.be.oneOf([null, undefined, '']);
  });

  test("should accept X-Correlation-ID header", function() {
    expect(res.getStatus()).to.equal(204);
  });

  test("should have CORS headers", function() {
    const corsHeader = res.getHeader('access-control-allow-origin');
    expect(corsHeader).to.exist;
  });
}
