meta {
  name: Cast Topic Vote
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/partners/{{testPartnerCompanyName}}/votes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Origin: https://staging.batbern.ch
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "topicId": "{{testTopicId}}",
    "voteValue": 5
  }
}

assert {
  res.status: eq 201
  res.body.voteValue: isDefined
  res.body.voteWeight: isDefined
}

tests {
  test("should return 201 status", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should cast vote on topic", function() {
    const body = res.getBody();
    expect(body.topicId).to.equal(bru.getEnvVar("testTopicId"));
    expect(body.voteValue).to.equal(5);
  });

  test("should calculate vote weight based on partnership tier", function() {
    const body = res.getBody();
    expect(body.voteWeight).to.be.a('number');
    expect(body.voteWeight).to.be.within(1, 5);
    // BRONZE=1, SILVER=2, GOLD=3, PLATINUM=4, STRATEGIC=5
  });

  test("should include voted timestamp", function() {
    const body = res.getBody();
    expect(body.votedAt).to.exist;
    const votedAt = new Date(body.votedAt);
    expect(votedAt).to.be.a('date');
  });

  test("should accept X-Correlation-ID header", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return location header", function() {
    const locationHeader = res.getHeader('location');
    if (locationHeader) {
      expect(locationHeader).to.include('/partners/');
      expect(locationHeader).to.include('/votes');
    }
  });
}
