meta {
  name: Add Partner Contact - Duplicate (409)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/partners/{{testPartnerCompanyName}}/contacts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Origin: https://staging.batbern.ch
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "username": "{{testContactUsername}}",
    "contactRole": "TECHNICAL",
    "isPrimary": false
  }
}

assert {
  res.status: eq 409
}

tests {
  test("should return 409 status when adding duplicate contact", function() {
    expect(res.getStatus()).to.equal(409);
  });

  test("should return ErrorResponse from shared-kernel", function() {
    const body = res.getBody();
    expect(body.message).to.exist;
    expect(body.message).to.include('already exists');
    expect(body.path).to.exist;
    expect(body.correlationId).to.exist;
  });

  test("should have CORS headers even on error", function() {
    const corsHeader = res.getHeader('access-control-allow-origin');
    expect(corsHeader).to.exist;
  });
}
