meta {
  name: List Partners
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/partners
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Origin: https://staging.batbern.ch
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.data: isArray
  res.body.metadata: isDefined
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should have pagination metadata", function() {
    const body = res.getBody();
    expect(body.metadata).to.be.an('object');
    expect(body.metadata.page).to.be.a('number');
    expect(body.metadata.limit).to.be.a('number');
    expect(body.metadata.totalItems).to.be.a('number');
  });

  test("should return array of partners", function() {
    const body = res.getBody();
    expect(body.data).to.be.an('array');
  });

  test("partner should have required fields", function() {
    const body = res.getBody();
    if (body.data && body.data.length > 0) {
      const partner = body.data[0];
      expect(partner.companyName).to.exist;
      expect(partner.partnershipLevel).to.exist;
      expect(partner.partnershipStartDate).to.exist;
      expect(partner.isActive).to.be.a('boolean');
    }
  });

  test("should accept X-Correlation-ID header", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should have CORS headers", function() {
    const corsHeader = res.getHeader('access-control-allow-origin');
    expect(corsHeader).to.exist;
  });
}
