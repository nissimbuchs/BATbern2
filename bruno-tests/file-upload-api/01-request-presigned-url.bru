meta {
  name: Request Presigned URL for Logo Upload
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/logos/presigned-url
  body: json
  auth: bearer
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept-Language: en-US
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "fileName": "test-logo-{{$timestamp}}.png",
    "fileSize": 1048576,
    "mimeType": "image/png"
  }
}

assert {
  res.status: eq 200
  res.body.uploadUrl: isDefined
  res.body.fileId: isDefined
  res.body.fileExtension: isDefined
}

script:post-response {
  // Store uploadId for subsequent tests
  if (res.getStatus() === 200) {
    const response = res.getBody();
    bru.setEnvVar("testUploadId", response.fileId);
    bru.setEnvVar("testFileExtension", response.fileExtension);
    bru.setEnvVar("testUploadUrl", response.uploadUrl);
    console.log("Generated presigned URL for upload ID:", response.fileId);
  }
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("should return presigned upload URL", function() {
    const body = res.getBody();
    expect(body.uploadUrl).to.exist;
    expect(body.uploadUrl).to.be.a('string');
    // Accept both AWS S3 (production/staging) and MinIO (local development)
    const isValidS3Url = body.uploadUrl.includes('s3.eu-central-1.amazonaws.com') || body.uploadUrl.includes('localhost:8450');
    expect(isValidS3Url).to.be.true;
  });
  
  test("should return file metadata", function() {
    const body = res.getBody();
    expect(body.fileId).to.exist;
    expect(body.fileId).to.be.a('string');
    expect(body.fileExtension).to.equal('png');
    expect(body.expiresInMinutes).to.equal(15);
  });
  
  test("should return required headers", function() {
    const body = res.getBody();
    expect(body.requiredHeaders).to.exist;
    expect(body.requiredHeaders).to.be.an('object');
  });
  
  test("should have CORS headers", function() {
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}
