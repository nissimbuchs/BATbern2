meta {
  name: Get Event Details - Expanded
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/events/{{createdEventCode}}?include=venue,speakers,sessions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

params:query {
  include: venue,speakers,sessions
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return event with expanded resources (Story 1.16.2: use eventCode)", function() {
    const event = res.getBody();
    expect(event.eventCode).to.equal(bru.getVar("createdEventCode"));
    // Note: venue, speakers, sessions might be null/empty if not set
  });

  test("should NOT have id field (Story 1.16.2: removed redundant id)", function() {
    expect(res.getBody().id).to.be.undefined;
  });
}
