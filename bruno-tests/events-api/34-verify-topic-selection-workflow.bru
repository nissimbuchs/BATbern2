meta {
  name: Verify Topic Selection Workflow State
  type: http
  seq: 34
}

get {
  url: {{baseUrl}}/events/{{createdEventCode}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
  res.body.workflowState: eq topic_selection
}

tests {
  test("should return event with TOPIC_SELECTION workflow state - Story 5.2 AC14, AC16", function() {
    const event = res.getBody();
    expect(event.eventCode).to.equal(bru.getVar("createdEventCode"));
    expect(event.workflowState).to.equal('topic_selection');
  });
}
