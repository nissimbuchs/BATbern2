meta {
  name: Verify Topic Selection Workflow State
  type: http
  seq: 34
}

get {
  url: {{baseUrl}}/events/{{createdEventCode}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
  res.body.workflowState: in [TOPIC_SELECTION, SPEAKER_IDENTIFICATION]
}

tests {
  test("should return event with workflow state advanced after topic selection - Story 5.2 AC14, AC16", function() {
    const event = res.getBody();
    expect(event.eventCode).to.equal(bru.getVar("createdEventCode"));
    // Workflow auto-advances to SPEAKER_IDENTIFICATION after topic is selected
    expect(event.workflowState).to.be.oneOf(['TOPIC_SELECTION', 'SPEAKER_IDENTIFICATION']);
  });
}
