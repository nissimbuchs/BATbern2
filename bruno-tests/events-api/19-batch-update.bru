meta {
  name: Batch Update Events
  type: http
  seq: 19
}

patch {
  url: {{baseUrl}}/events
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  [
    {
      "eventCode": "{{createdEventCode}}",
      "description": "Batch updated description"
    }
  ]
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return batch update results", function() {
    const result = res.getBody();
    expect(result.summary).to.be.an('object');
    expect(result.summary.successful).to.be.a('number');
    expect(result.summary.failed).to.be.a('number');
    expect(result.successful).to.be.an('array');
    expect(result.failed).to.be.an('array');
  });
}
