meta {
  name: Create Event for Topic Tests
  type: http
  seq: 30.5
}

post {
  url: {{baseUrl}}/events
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

script:pre-request {
  // Generate unique eventNumber that fits in Java int32
  const now = Date.now();
  const eventNumber = (now % 1000000) + 900000;

  bru.setVar("testTimestamp2", now);
  bru.setVar("eventNumber2", eventNumber);
}

body:json {
  {
    "title": "Bruno Topic Test Event {{testTimestamp2}}",
    "eventNumber": {{eventNumber2}},
    "date": "2026-03-15T09:00:00Z",
    "registrationDeadline": "2026-03-01T23:59:59Z",
    "venueName": "Topic Test Venue",
    "venueAddress": "Test Address 2, 3000 Bern",
    "venueCapacity": 120,
    "workflowState": "CREATED",
    "organizerUsername": "{{organizerUsername}}",
    "description": "Event for topic selection and speaker pool tests",
    "eventType": "EVENING"
  }
}

assert {
  res.status: eq 201
  res.body.eventCode: isDefined
}

tests {
  test("should return 201 status", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should save eventCode for topic/speaker tests", function() {
    const event = res.getBody();
    bru.setVar("createdEventCode", event.eventCode);
    bru.setVar("createdEventNumber", event.eventNumber);
  });
}
