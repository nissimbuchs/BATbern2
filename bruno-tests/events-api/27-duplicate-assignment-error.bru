meta {
  name: Duplicate Assignment Error
  type: http
  seq: 27
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/sessions/{{createdSessionSlug}}/speakers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "username": "{{testSpeakerUsername}}",
    "speakerRole": "CO_SPEAKER",
    "presentationTitle": "Another Presentation"
  }
}

assert {
  res.status: in [400, 409]
}

tests {
  test("should prevent duplicate assignment (Story 1.15a.1b: AC8)", function() {
    // First need to assign the speaker
    // This test assumes speaker was already assigned in test 01
    // If running this test after 06 (remove), speaker won't exist and this will succeed (201)
    // If speaker exists, should return 400 or 409
    const status = res.getStatus();
    expect([201, 400, 409]).to.include(status);
  });

  test("should return error message if duplicate", function() {
    const status = res.getStatus();
    if (status === 400 || status === 409) {
      const body = res.getBody();
      expect(body).to.exist;
      // Error response should contain message
      if (typeof body === 'object') {
        expect(body.message || body.error).to.exist;
      }
    }
  });

  test("should require ORGANIZER role", function() {
    const status = res.getStatus();
    expect([201, 400, 403, 409]).to.include(status);
  });
}

script:post-response {
  const status = res.getStatus();
  if (status === 400 || status === 409) {
    console.log("Correctly prevented duplicate speaker assignment");
  } else if (status === 201) {
    console.log("Speaker was not previously assigned, assignment succeeded");
    // Store username for later tests
    bru.setVar("testSpeakerUsername", bru.getVar("testSpeakerUsername"));
  }
}
