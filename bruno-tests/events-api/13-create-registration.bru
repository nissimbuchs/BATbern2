meta {
  name: Create Registration
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/registrations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "attendeeUsername": "test.attendee",
    "attendeeEmail": "test.attendee@example.com",
    "attendeeName": "Test Attendee",
    "status": "registered",
    "registrationDate": "2025-10-27T10:00:00Z"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("should return 201 status", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created registration with registrationCode and attendeeUsername (Story 1.16.2)", function() {
    const registration = res.getBody();
    expect(registration.registrationCode).to.be.a('string');
    expect(registration.registrationCode).to.match(/^BATbern[0-9]+-[a-z]+\.[a-z]+(-[0-9]+)?$/);
    expect(registration.attendeeUsername).to.equal('test.attendee');
    expect(registration.attendeeEmail).to.equal('test.attendee@example.com');
    expect(registration.attendeeName).to.equal('Test Attendee');
    expect(registration.eventCode).to.equal(bru.getVar("createdEventCode"));
  });

  test("should verify no UUID id field (Story 1.16.2)", function() {
    const registration = res.getBody();
    expect(registration.id).to.be.undefined;
    expect(registration.attendeeId).to.be.undefined;
  });

  test("should save registration code", function() {
    bru.setVar("createdRegistrationCode", res.getBody().registrationCode);
  });
}
