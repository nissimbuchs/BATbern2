meta {
  name: List Event Registrations
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/events/{{createdEventCode}}/registrations
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return registrations array (Story 2.2a)", function() {
    const registrations = res.getBody();
    expect(registrations).to.be.an('array');
    expect(registrations.length).to.be.greaterThan(0);
  });

  test("should return enriched registrations with user data (Story 2.2a: ADR-004)", function() {
    const registrations = res.getBody();
    if (registrations.length > 0) {
      const registration = registrations[0];

      // Registration code format: {eventCode}-reg-{6 random chars}
      expect(registration.registrationCode).to.be.a('string');
      expect(registration.registrationCode).to.match(/^BATbern[0-9]+-reg-[A-Z0-9]{6}$/);

      // Enriched user data from User Management Service
      expect(registration.attendeeUsername).to.be.a('string');
      expect(registration.attendeeFirstName).to.be.a('string');
      expect(registration.attendeeLastName).to.be.a('string');
      expect(registration.attendeeEmail).to.be.a('string');

      // Registration details
      expect(registration.eventCode).to.be.a('string');
      expect(registration.status).to.be.a('string');
      expect(registration.registrationDate).to.be.a('string');
      expect(registration.createdAt).to.be.a('string');
      expect(registration.updatedAt).to.be.a('string');

      // No UUID id fields (ADR-003)
      expect(registration.id).to.be.undefined;
      expect(registration.attendeeId).to.be.undefined;
    }
  });
}
