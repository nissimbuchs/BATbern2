meta {
  name: Remove Speaker from Session
  type: http
  seq: 26
}

delete {
  url: {{baseUrl}}/events/{{createdEventCode}}/sessions/{{createdSessionSlug}}/speakers/{{testSpeakerUsername}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 204
}

tests {
  test("should return 204 No Content status (Story 1.15a.1b: AC4)", function() {
    expect(res.getStatus()).to.equal(204);
  });

  test("should have empty response body", function() {
    const body = res.getBody();
    expect(body).to.satisfy(b => b === null || b === undefined || b === '');
  });

  test("should require ORGANIZER role (Story 1.15a.1b: AC4)", function() {
    // If test runs with non-ORGANIZER token, should get 403
    const status = res.getStatus();
    expect([204, 403]).to.include(status);
  });
}

script:post-response {
  // Verify speaker was actually removed
  if (res.getStatus() === 204) {
    console.log("Speaker successfully removed from session");
  }
}
