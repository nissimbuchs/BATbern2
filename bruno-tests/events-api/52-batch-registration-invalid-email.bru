meta {
  name: Batch Registration - Invalid Email
  type: http
  seq: 52
}

post {
  url: {{baseUrl}}/events/batch_registrations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "participantEmail": "invalid-email",
    "firstName": "Test",
    "lastName": "Participant",
    "registrations": [
      {
        "eventCode": "BATbern1",
        "status": "ATTENDED"
      }
    ]
  }
}

assert {
  res.status: eq 400
  res.body.code: eq VALIDATION_ERROR
}

tests {
  test("should return 400 for invalid email", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return validation error details (Story BAT-12)", function() {
    const response = res.getBody();
    expect(response.error).to.include('Validation');
    expect(response.code).to.equal('VALIDATION_ERROR');
  });
}
