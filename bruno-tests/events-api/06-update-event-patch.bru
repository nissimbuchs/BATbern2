meta {
  name: Update Event (Patch)
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/events/{{createdEventCode}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "title": "Bruno Test Event - Updated",
    "description": "Updated description via patch"
  }
}

assert {
  res.status: eq 200
  res.body.eventCode: isDefined
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should update event fields (Story 1.16.2: use eventCode)", function() {
    const event = res.getBody();
    expect(event.eventCode).to.equal(bru.getVar("createdEventCode"));
    expect(event.title).to.equal('Bruno Test Event - Updated');
    expect(event.description).to.equal('Updated description via patch');
  });

  test("should NOT have id field (Story 1.16.2: removed redundant id)", function() {
    expect(res.getBody().id).to.be.undefined;
  });
}
