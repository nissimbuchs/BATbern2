meta {
  name: Send Reminder With Missing Type Returns 400 (Story 6.5 AC8)
  type: http
  seq: 64
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/speaker-pool/{{createdSpeakerPoolId}}/send-reminder
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "tier": "TIER_1"
  }
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 when reminderType is missing - Story 6.5 AC8", function() {
    expect(res.getStatus()).to.equal(400);
  });
}
