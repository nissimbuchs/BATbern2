meta {
  name: Batch Registration - Full Success
  type: http
  seq: 50
}

post {
  url: {{baseUrl}}/events/batch_registrations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "participantEmail": "test.participant@example.com",
    "firstName": "Test",
    "lastName": "Participant",
    "registrations": [
      {
        "eventCode": "BATbern1",
        "status": "ATTENDED"
      },
      {
        "eventCode": "BATbern2",
        "status": "ATTENDED"
      }
    ]
  }
}

assert {
  res.status: eq 200
  res.body.username: isDefined
  res.body.totalRegistrations: eq 2
  res.body.successfulRegistrations: eq 2
}

tests {
  test("should return 200 status", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should create all registrations successfully (Story BAT-12)", function() {
    const response = res.getBody();
    expect(response.username).to.be.a('string');
    expect(response.totalRegistrations).to.equal(2);
    expect(response.successfulRegistrations).to.equal(2);
    expect(response.failedRegistrations).to.be.an('array').that.is.empty;
    expect(response.errors).to.be.an('array').that.is.empty;
  });

  test("should return valid username format", function() {
    const response = res.getBody();
    expect(response.username).to.match(/^[a-z]+\.[a-z]+(\.[0-9]+)?$/);
  });
}
