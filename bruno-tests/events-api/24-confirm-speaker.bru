meta {
  name: Confirm Speaker
  type: http
  seq: 24
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/sessions/{{createdSessionSlug}}/speakers/{{testSpeakerUsername}}/confirm
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
  res.body.confirmed: eq true
}

tests {
  test("should return 200 OK status", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("should set isConfirmed to true (Story 1.15a.1b: AC5)", function() {
    const speaker = res.getBody();
    expect(speaker.confirmed).to.equal(true);
  });
  
  test("should return enriched speaker data", function() {
    const speaker = res.getBody();
    expect(speaker.firstName).to.be.a('string');
    expect(speaker.lastName).to.be.a('string');
    expect(speaker.speakerRole).to.be.a('string');
  });
  
  test("should require ORGANIZER role (Story 1.15a.1b: AC5)", function() {
    // If test runs with non-ORGANIZER token, should get 403
    const status = res.getStatus();
    expect([200, 403]).to.include(status);
  });
  
  test("should be idempotent (can confirm again)", function() {
    // Confirming an already confirmed speaker should still return 200
    expect(res.getStatus()).to.equal(200);
  });
}
