meta {
  name: Create Event
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/events
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

script:pre-request {
  // Generate unique eventNumber that fits in Java int32 (-2,147,483,648 to 2,147,483,647)
  const now = Date.now();

  // Use modulo to get last 6 digits + offset = 900000-1899999 (fits in int32)
  const eventNumber = (now % 1000000) + 900000;

  bru.setVar("testTimestamp", now);
  bru.setVar("eventNumber", eventNumber);
}

body:json {
  {
    "title": "Bruno Test Event {{testTimestamp}}",
    "eventNumber": {{eventNumber}},
    "date": "2025-12-15T09:00:00Z",
    "registrationDeadline": "2025-12-01T23:59:59Z",
    "venueName": "Test Venue",
    "venueAddress": "Test Address 1, 3000 Bern",
    "venueCapacity": 100,
    "workflowState": "CREATED",
    "organizerUsername": "{{organizerUsername}}",
    "description": "Test event created by Bruno API tests",
    "eventType": "EVENING"
  }
}

assert {
  res.status: eq 201
  res.body.eventCode: isDefined
  res.body.title: isDefined
}

tests {
  test("should return 201 status", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created event with eventCode (Story 1.16.2: use eventCode as identifier)", function() {
    const event = res.getBody();
    expect(event.eventCode).to.be.a('string');
    expect(event.title).to.include('Bruno Test Event');
    expect(event.workflowState).to.equal('CREATED');
    expect(event.eventNumber).to.be.a('number');
  });

  test("should NOT have id field (Story 1.16.2: removed redundant id)", function() {
    const event = res.getBody();
    expect(event.id).to.be.undefined;
  });

  test("should save eventCode for later tests (Story 1.16.2)", function() {
    const event = res.getBody();
    bru.setVar("createdEventCode", event.eventCode);
    bru.setVar("createdEventNumber", event.eventNumber);
  });
}
