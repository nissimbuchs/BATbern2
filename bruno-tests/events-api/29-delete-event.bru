meta {
  name: Delete Event (Cleanup)
  type: http
  seq: 29
}

delete {
  url: {{baseUrl}}/events/{{createdEventCode}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 204
}

tests {
  test("should return 204 status", function() {
    expect(res.getStatus()).to.equal(204);
  });
  
  test("cleanup: clear event code (Story 1.16.2)", function() {
    bru.setVar("createdEventCode", null);
  });
}
