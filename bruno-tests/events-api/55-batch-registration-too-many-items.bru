assert {
  res.status: eq 400
}

tests {
  test("should return 400 for too many registrations", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should validate maxItems constraint (Story BAT-12)", function() {
    const response = res.getBody();
    expect(response.error).to.include('Validation');
    expect(response.message).to.include('at most 100');
  });
}
