meta {
  name: Multiple Speakers with Different Roles
  type: http
  seq: 28
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/sessions/{{createdSessionSlug}}/speakers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "username": "{{testModeratorUsername}}",
    "speakerRole": "MODERATOR",
    "presentationTitle": null
  }
}

assert {
  res.status: eq 201
  res.body.speakerRole: eq MODERATOR
}

tests {
  test("should assign second speaker with different role (Story 1.15a.1b: AC3)", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should support MODERATOR role", function() {
    const speaker = res.getBody();
    expect(speaker.speakerRole).to.equal('MODERATOR');
  });

  test("should allow null presentationTitle for moderators", function() {
    const speaker = res.getBody();
    // Moderators don't need presentation titles
    expect(speaker.presentationTitle).to.satisfy(t => t === null || t === undefined);
  });

  test("should return enriched User data for second speaker", function() {
    const speaker = res.getBody();
    expect(speaker.username).to.be.a('string');
    expect(speaker.firstName).to.be.a('string');
    expect(speaker.lastName).to.be.a('string');
  });

  test("should verify multiple speakers can be listed", function() {
    // This would require a GET request to verify
    // Just ensure the assignment succeeded
    expect(res.getStatus()).to.equal(201);
  });
}

script:post-response {
  if (res.getStatus() === 201) {
    console.log("Successfully assigned second speaker with MODERATOR role");

    // Now verify we can list both speakers
    // Store moderator username for potential cleanup
    bru.setVar("testModeratorUsername", bru.getVar("testModeratorUsername"));
  }
}
