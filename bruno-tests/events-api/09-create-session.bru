meta {
  name: Create Session
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/events/{{createdEventCode}}/sessions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "title": "Opening Keynote",
    "description": "Welcome and introduction to the event",
    "sessionType": "keynote",
    "startTime": "2025-12-15T09:00:00Z",
    "endTime": "2025-12-15T10:00:00Z",
    "room": "Main Hall",
    "capacity": 100,
    "language": "de"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("should return 201 status", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("should return created session with sessionSlug (Story 1.16.2: uses meaningful IDs)", function() {
    const session = res.getBody();
    expect(session.sessionSlug).to.be.a('string');
    expect(session.sessionSlug).to.match(/^[a-z0-9]+(-[a-z0-9]+)*$/);
    expect(session.title).to.equal('Opening Keynote');
    expect(session.sessionType).to.equal('keynote');
    expect(session.eventCode).to.equal(bru.getVar("createdEventCode"));
  });

  test("should verify no UUID id field (Story 1.16.2)", function() {
    const session = res.getBody();
    expect(session.id).to.be.undefined;
  });

  test("should save session slug", function() {
    bru.setVar("createdSessionSlug", res.getBody().sessionSlug);
  });
}
