meta {
  name: Batch Registration - Empty Registrations
  type: http
  seq: 53
}

post {
  url: {{baseUrl}}/events/batch_registrations
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "participantEmail": "test@example.com",
    "firstName": "Test",
    "lastName": "Participant",
    "registrations": []
  }
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 for empty registrations array", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should validate minItems constraint (Story BAT-12)", function() {
    const response = res.getBody();
    expect(response.error).to.include('Validation');
    expect(response.message).to.include('at least 1');
  });
}
