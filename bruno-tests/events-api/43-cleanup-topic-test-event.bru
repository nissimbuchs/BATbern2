meta {
  name: Cleanup Topic Test Event
  type: http
  seq: 43
}

delete {
  url: {{baseUrl}}/events/{{createdEventCode}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 204
}

tests {
  test("should delete topic test event created in 30a", function() {
    // Accept both 204 (deleted) and 404 (already deleted)
    const status = res.getStatus();
    expect([204, 404]).to.include(status);
  });

  test("cleanup: clear event code", function() {
    bru.setVar("createdEventCode", null);
  });
}
