meta {
  name: Validation Failure (Insufficient Speakers)
  type: http
  seq: 4
}

docs {
  Story 5.1a - AC20: Validation failure for insufficient speakers

  Test that transition to SPEAKER_OUTREACH fails if validation criteria not met
}

put {
  url: {{baseUrl}}/events/{{createdEventCode}}/workflow/transition
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "targetState": "SPEAKER_OUTREACH"
  }
}

assert {
  res.status: eq 422
  res.body.message: isDefined
  res.body.details: isDefined
}

tests {
  test("should return 422 status for validation failure", function() {
    expect(res.getStatus()).to.equal(422);
  });

  test("should return validation error message", function() {
    const error = res.getBody();
    expect(error.message).to.be.a('string');
    expect(error.message.toLowerCase()).to.match(/insufficient|minimum|validation/);
  });

  test("should have error code WORKFLOW_VALIDATION_FAILED", function() {
    const error = res.getBody();
    expect(error.code).to.equal('WORKFLOW_VALIDATION_FAILED');
  });

  test("should include validation details context", function() {
    const error = res.getBody();
    expect(error.details).to.be.an('object');
  });
}
