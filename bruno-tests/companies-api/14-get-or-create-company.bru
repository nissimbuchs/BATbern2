meta {
  name: Get or Create Company
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/companies:get-or-create
  body: json
  auth: inherit
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept-Language: en-US
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "displayName": "Test Co Bruno"
  }
}

assert {
  res.status: eq 200
  res.body.name: isDefined
  res.body.displayName: eq Test Co Bruno
}

script:post-response {
  // ADR-003: Store company name (slug) for idempotency test
  if (res.getStatus() === 200) {
    const company = res.getBody();
    bru.setEnvVar("getOrCreateCompanyName", company.name);
    console.log("Got/created company with name:", company.name, "display:", company.displayName);
  }
}

tests {
  test("should return 200 (get or create is idempotent)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return company with generated slug name", function() {
    const body = res.getBody();
    expect(body).to.be.an('object');
    expect(body.name).to.exist;
    expect(body.name).to.be.a('string');
    expect(body.name).to.match(/^[a-z0-9-]+$/); // ADR-003: alphanumeric slug
    expect(body.name.length).to.be.at.most(12); // ADR-003: max 12 chars
  });

  test("should have correct displayName from request", function() {
    const body = res.getBody();
    expect(body.displayName).to.equal('Test Co Bruno');
  });

  test("should convert displayName to slug (ADR-003)", function() {
    const body = res.getBody();
    // "Test Co Bruno" should become "testcobruno" (lowercase, no spaces)
    expect(body.name).to.equal('testcobruno');
  });

  test("should NOT have id field (Story 1.16.2: name is the identifier)", function() {
    const body = res.getBody();
    expect(body.id).to.be.undefined;
  });

  test("should have metadata fields", function() {
    const body = res.getBody();
    expect(body.isVerified).to.be.a('boolean');
    expect(body.isVerified).to.equal(false); // New companies start unverified
    expect(body.createdAt).to.exist;
    expect(body.updatedAt).to.exist;
    expect(body.createdBy).to.exist;
  });

  test("should have CORS headers", function() {
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}
