meta {
  name: Update Company (PATCH)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/companies/{{testCompanyName}}
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  X-Correlation-ID: test-{{timestamp}}
}

body:json {
  {
    "name": "{{testCompanyName}}",
    "displayName": "Bruno Test Co (Updated)",
    "industry": "Software",
    "website": "https://bruno-test-updated.example.com",
    "description": "Updated test company - Bruno API tests"
  }
}

assert {
  res.status: eq 200
  res.body.name: isDefined
}

tests {
  test("should update company successfully", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return updated company", function() {
    const body = res.getBody();
    expect(body.displayName).to.equal('Bruno Test Co (Updated)');
    expect(body.industry).to.equal('Software');
    expect(body.website).to.equal('https://bruno-test-updated.example.com');
  });

  test("should preserve company name (Story 1.16.2: name is identifier)", function() {
    const body = res.getBody();
    const expectedName = bru.getEnvVar("testCompanyName");
    expect(body.name).to.equal(expectedName);
  });

  test("should NOT have id field (Story 1.16.2: removed redundant id)", function() {
    const body = res.getBody();
    expect(body.id).to.be.undefined;
  });

  test("should have CORS headers", function() {
    // Access headers via res.headers object (lowercase keys)
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}
