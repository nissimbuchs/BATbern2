meta {
  name: Delete Company
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/companies/{{testCompanyId}}
  body: none
  auth: inherit
}

headers {
  X-Correlation-ID: test-{{timestamp}}
}

assert {
  res.status: eq 204
}

tests {
  test("should delete company successfully", function() {
    expect(res.getStatus()).to.equal(204);
  });

  test("should have CORS headers", function() {
    const corsHeader = res.getHeader('access-control-allow-origin');
    expect(corsHeader).to.exist;
  });
}
