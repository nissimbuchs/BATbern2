meta {
  name: Get Company with Logo
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/companies/{{testCompanyId}}?include=logo
  body: none
  auth: inherit
}

headers {
  X-Correlation-ID: test-{{timestamp}}
}

script:post-response {
  const responseTime = res.getResponseTime();
  console.log(`Response time: ${responseTime}ms`);
}

tests {
  test("should return 200 status", function() {
    expect(res.status).to.equal(200);
  });

  test("should have company logo", function() {
    expect(res.body.logo).to.exist;
  });

  test("logo should have url", function() {
    expect(res.body.logo.url).to.exist;
  });

  test("logo should have s3Key", function() {
    expect(res.body.logo.s3Key).to.exist;
  });

  test("logo should have fileId", function() {
    expect(res.body.logo.fileId).to.exist;
  });

  test("logo URL should be from CloudFront", function() {
    expect(res.body.logo.url).to.include('cloudfront.net');
  });
}

assert {
  res.status: eq 200
  res.body.logo: isDefined
  res.body.logo.url: isDefined
}
