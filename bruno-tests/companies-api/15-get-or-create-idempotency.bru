meta {
  name: Get or Create Company - Idempotency Test
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/companies:get-or-create
  body: json
  auth: inherit
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept-Language: en-US
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "displayName": "Test Co Bruno"
  }
}

assert {
  res.status: eq 200
  res.body.name: eq {{getOrCreateCompanyName}}
  res.body.displayName: eq Test Co Bruno
}

tests {
  test("should return existing company (idempotent)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return same company name as previous call", function() {
    const body = res.getBody();
    const previousName = bru.getEnvVar("getOrCreateCompanyName");
    expect(body.name).to.equal(previousName);
    console.log("Idempotency verified: returned same company name:", body.name);
  });

  test("should have same displayName", function() {
    const body = res.getBody();
    expect(body.displayName).to.equal('Test Co Bruno');
  });

  test("should maintain slug format (ADR-003)", function() {
    const body = res.getBody();
    expect(body.name).to.equal('testcobruno');
  });
}
