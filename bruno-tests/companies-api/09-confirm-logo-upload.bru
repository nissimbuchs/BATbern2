meta {
  name: Confirm Logo Upload
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/companies/{{testCompanyName}}/logo/confirm
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  X-Correlation-ID: test-{{timestamp}}
}

body:json {
  {
    "fileId": "{{logoFileId}}",
    "fileExtension": "{{logoFileExtension}}",
    "checksum": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
  }
}

script:pre-request {
  // This test requires presigned URL request to have run first
  const logoFileId = bru.getEnvVar("logoFileId");
  if (!logoFileId) {
    throw new Error("logoFileId not set. Run 08-request-logo-presigned-url first.");
  }
}

script:post-response {
  if (res.status === 200) {
    console.log(`Logo confirmed - URL: ${res.body.logoUrl}`);
    bru.setEnvVar("companyLogoUrl", res.body.logoUrl);
  }
}

tests {
  test("should confirm logo upload successfully", function() {
    expect(res.status).to.equal(200);
  });

  test("should return logo URL", function() {
    expect(res.body.logoUrl).to.exist;
  });

  test("logo URL should be valid", function() {
    // Development: localhost MinIO (http://localhost:9000)
    // Production: CloudFront CDN (cloudfront.net)
    const logoUrl = res.body.logoUrl;
    expect(logoUrl).to.be.a('string');
    expect(logoUrl).to.have.length.greaterThan(0);
    // Environment-agnostic: just verify it's a valid URL format
    expect(logoUrl).to.match(/^https?:\/\/.+/);
  });

  test("should have CORS headers", function() {
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}

assert {
  res.status: eq 200
  res.body.logoUrl: isDefined
}
