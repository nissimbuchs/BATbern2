meta {
  name: Verify Company
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/companies/{{testCompanyName}}/verify
  body: none
  auth: inherit
}

headers {
  X-Correlation-ID: test-{{timestamp}}
}

script:pre-request {
  // This test requires a company to exist
  const testCompanyName = bru.getEnvVar("testCompanyName");
  if (!testCompanyName) {
    throw new Error("testCompanyName not set. Run 01-create-company first.");
  }
}

script:post-response {
  if (res.status === 200) {
    console.log(`Company verified: ${res.body.name}`);
  }
}

tests {
  test("should verify company successfully", function() {
    expect(res.status).to.equal(200);
  });

  test("should return company data (Story 1.16.2: uses name as identifier)", function() {
    expect(res.body.name).to.equal(bru.getEnvVar("testCompanyName"));
    expect(res.body.id).to.be.undefined; // Story 1.16.2: no id field
  });

  test("company should be marked as verified", function() {
    expect(res.body.isVerified).to.equal(true);
  });

  test("should have CORS headers", function() {
    const headers = res.getHeaders();
    const corsHeader = headers['access-control-allow-origin'];
    expect(corsHeader).to.exist;
  });
}

assert {
  res.status: eq 200
  res.body.isVerified: eq true
}
