meta {
  name: Verify Company Deletion
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/companies/{{testCompanyId}}
  body: none
  auth: inherit
}

headers {
  X-Correlation-ID: test-{{timestamp}}
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 for deleted company", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should have error message", function() {
    const body = res.getBody();
    expect(body.error).to.exist;
  });
}
