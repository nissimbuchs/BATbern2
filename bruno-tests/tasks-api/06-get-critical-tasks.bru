meta {
  name: Get Critical Tasks
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/tasks/my-tasks
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

params:query {
  critical: true
}

assert {
  res.status: eq 200
  res.body: isDefined
}

tests {
  test("should return 200 status - Story 5.5 AC24", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return tasks array with valid structure - Story 5.5 AC24", function() {
    const response = res.getBody();
    expect(response).to.be.an('array');

    // Verify tasks have required fields
    if (response.length > 0) {
      response.forEach(task => {
        expect(task.id).to.be.a('string');
        expect(task.eventId).to.be.a('string');
        expect(task.taskName).to.be.a('string');
        expect(task.status).to.be.oneOf(['pending', 'todo', 'in_progress', 'completed']);
        // dueDate is optional but should be a string if present
        if (task.dueDate) {
          expect(task.dueDate).to.be.a('string');
        }
      });
    }
  });
}
