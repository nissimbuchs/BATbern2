meta {
  name: Filter Speakers by Languages (AC4)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/speakers?languages=de
  body: none
  auth: none
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
}

params:query {
  languages: de
}

assert {
  res.status: eq 200
  res.body.data: isArray
}

tests {
  test("should return 200 status with languages filter (AC4)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return paginated results", function() {
    const body = res.getBody();
    expect(body.pagination).to.be.an('object');
    expect(body.data).to.be.an('array');
  });

  test("should only return speakers who speak German", function() {
    const body = res.getBody();
    body.data.forEach(speaker => {
      expect(speaker.languages).to.be.an('array');
      expect(speaker.languages).to.include('de');
    });
  });
}
