meta {
  name: Filter Speakers by Expertise Areas (AC4)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/speakers?expertiseAreas=Security
  body: none
  auth: none
}

headers {
  X-Correlation-ID: {{$guid}}
  Accept-Language: de-CH
  Accept: application/json
}

params:query {
  expertiseAreas: Security
}

assert {
  res.status: eq 200
  res.body.data: isArray
}

tests {
  test("should return 200 status with expertiseAreas filter (AC4)", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return paginated results", function() {
    const body = res.getBody();
    expect(body.pagination).to.be.an('object');
    expect(body.data).to.be.an('array');
  });

  test("should only return speakers with Security expertise", function() {
    const body = res.getBody();
    body.data.forEach(speaker => {
      expect(speaker.expertiseAreas).to.be.an('array');
      expect(speaker.expertiseAreas).to.include('Security');
    });
  });
}
