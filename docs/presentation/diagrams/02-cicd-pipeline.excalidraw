        "group-box-pipeline"
      ],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "containerId": "shape-box-pipeline",
      "text": "    Build Pipeline\n        (.github/workflows/build.yml)\n    \n    Stage 1a: frontend\n          npm ci → lint → test → build\n    Stage 1b: shared-kernel check\n    Stage 2: 6 services (PARALLEL)\n          api-gateway\n          event-management\n          speaker-coordination\n          partner-coordination\n          attendee-experience\n          company-user-management\n    Stage 3: SonarCloud multi-module\n    Stage 4: ▶ deploy-staging.yml",
      "fontSize": 17.708634393063583,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "autoResize": false,
      "lineHeight": 1.25,
      "originalText": "    Build Pipeline\n        (.github/workflows/build.yml)\n    \n    Stage 1a: frontend\n          npm ci → lint → test → build\n    Stage 1b: shared-kernel check\n    Stage 2: 6 services (PARALLEL)\n          api-gateway\n          event-management\n          speaker-coordination\n          partner-coordination\n          attendee-experience\n          company-user-management\n    Stage 3: SonarCloud multi-module\n    Stage 4: ▶ deploy-staging.yml",
