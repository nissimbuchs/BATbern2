      "roundness": null,
      "boundElements": [],
      "containerId": "shape-box-pipeline",
      "text": "Build Pipeline (.github/workflows/build.yml)\n\nStage 1: shared-kernel check\nStage 2: 6 services (PARALLEL)\n  api-gateway\n  event-management\n  speaker-coordination\n  partner-coordination\n  attendee-experience\n  company-user-management\nStage 3: frontend\n  npm ci \u2192 lint \u2192 test \u2192 build\nStage 4: SonarCloud multi-module\nStage 5: \u25b6 deploy-staging.yml",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "autoResize": false,
      "lineHeight": 1.4,
      "originalText": "Build Pipeline (.github/workflows/build.yml)\n\nStage 1: shared-kernel check\nStage 2: 6 services (PARALLEL)\n  api-gateway\n  event-management\n  speaker-coordination\n  partner-coordination\n  attendee-experience\n  company-user-management\nStage 3: frontend\n  npm ci \u2192 lint \u2192 test \u2192 build\nStage 4: SonarCloud multi-module\nStage 5: \u25b6 deploy-staging.yml"
    },
