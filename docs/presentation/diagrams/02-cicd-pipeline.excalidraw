      "boundElements": [],
      "containerId": "shape-box-push",
      "text": "git push → pre-push hook\n\nSmart change detection\nshared-kernel changed? → test ALL\ndocs/infra only? → SKIP tests\nsingle service? → test that service\n\nJava: Testcontainers + JaCoCo\nFrontend: Vitest coverage",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
