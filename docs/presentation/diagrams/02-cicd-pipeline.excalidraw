    {
      "id": "text-box-pipeline",
      "type": "text",
      "x": 564.4429924584538,
      "y": 175.4561619400289,
      "width": 331.875,
      "height": 332.0368948699422,
      "angle": 0,
      "strokeColor": "#ffffff",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
