# BATbern Platform - Environment Variables
# Copy this file to .env and configure for your environment

# ============================================================================
# Application Environment
# ============================================================================
SPRING_PROFILES_ACTIVE=local
LOG_LEVEL=DEBUG
APP_ENVIRONMENT=development

# ============================================================================
# Database Configuration (Local PostgreSQL)
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=batbern
DB_USER=batbern_user
DB_PASSWORD=batbern-dev-password
DATABASE_URL=jdbc:postgresql://postgres:5432/batbern

# PostgreSQL Port (exposed to host)
POSTGRES_PORT=5432

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=eu-central-1
AWS_PROFILE=batbern-dev

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=eu-central-1_camJHQhZ8
COGNITO_CLIENT_ID=5h9421vo002bi7udjdu5orp7u3

# AWS EventBridge
EVENT_BUS_NAME=batbern-development

# Enable/Disable Cognito Authentication (set to false for local dev without AWS)
ENABLE_COGNITO_AUTH=true

# ============================================================================
# API Gateway Configuration
# ============================================================================
API_GATEWAY_PORT=8080

# ============================================================================
# Service Ports (exposed to host)
# ============================================================================
# API Gateway: 8080
# Company-User Management Service: 8081
# Event Management Service: 8082
# Speaker Coordination Service: 8083
# Partner Coordination Service: 8084
# Attendee Experience Service: 8085

# ============================================================================
# Development Notes
# ============================================================================
# For local development with PostgreSQL:
# - Set DB_HOST=postgres (Docker network) or DB_HOST=localhost (from host)
# - Run: docker-compose up postgres to start only PostgreSQL
# - Run: docker-compose up to start all services
#
# For AWS RDS development:
# - Set DB_HOST to your RDS endpoint
# - Ensure AWS credentials are configured
# - Run services individually or use docker-compose
